<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">
        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="6dp"
            android:src="@drawable/chevron"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Delivery Address"
            android:textSize="22sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#212121"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="5dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter your details for a smooth delivery"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="25dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="15dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="15dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <EditText
                    android:id="@+id/userName"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Receiver's Name"
                    android:paddingLeft="15dp"
                    android:background="@drawable/edittext_white_bg"
                    android:layout_marginBottom="12dp"
                    android:textSize="15sp"/>

                <EditText
                    android:id="@+id/userPhone"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Phone Number"
                    android:inputType="phone"
                    android:paddingLeft="15dp"
                    android:background="@drawable/edittext_white_bg"
                    android:textSize="15sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="15dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="15dp">

                <TextView
                    android:id="@+id/currentLocationBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="📍 Use Current Location"
                    android:textColor="#FF6F00"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="15dp"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <EditText
                    android:id="@+id/userAddress"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:hint="Full Address (Flat no, Building, Street...)"
                    android:gravity="top"
                    android:padding="15dp"
                    android:background="@drawable/edittext_white_bg"
                    android:textSize="15sp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/proceedToPayBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="SAVE AND PROCEED"
            android:backgroundTint="#FF6F00"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            app:cornerRadius="12dp"/>

    </LinearLayout>
</ScrollView>